#!/bin/sh
# Doc-state lints BEFORE the commit enters history (Decision Log v0.49):
# four author-catches in one day showed the CI lint pays but bites AFTER the
# commit (hence the fix-commits). Same test, one step earlier. Structure, not
# memory -- applied earlier in the pipeline.
PY=".venv/Scripts/python.exe"
[ -x "$PY" ] || PY=".venv/bin/python"
if [ ! -x "$PY" ]; then
    echo "pre-commit: venv python not found (.venv). Run: uv venv .venv --python 3.13 && uv pip install -e .[dev,agent,report]" >&2
    exit 1
fi
"$PY" -m pytest tests/test_doc_headers.py -q || {
    echo "" >&2
    echo "pre-commit: doc-header lints FAILED -- fix headers/cites before committing (they were about to drift into history)." >&2
    exit 1
}
